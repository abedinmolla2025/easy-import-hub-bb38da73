{
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.noorapp.in" }],
      "destination": "https://noorapp.in/$1",
      "statusCode": 301
    },
    {
      "source": "/bukhari",
      "destination": "/hadith/sahih-bukhari",
      "statusCode": 301
    },
    {
      "source": "/hadith/bukhari",
      "destination": "/hadith/sahih-bukhari",
      "statusCode": 301
    },
    {
      "source": "/sahih-al-bukhari",
      "destination": "/hadith/sahih-bukhari",
      "statusCode": 301
    },
    {
      "source": "/sahih-al-bukhari/:lang",
      "destination": "/hadith/sahih-bukhari/:lang",
      "statusCode": 301
    },
    {
      "source": "/app/noorapp.apk",
      "destination": "/download",
      "statusCode": 301
    },
    {
      "source": "/names",
      "destination": "/baby-names",
      "statusCode": 301
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets|favicon|og-|pwa-|manifest|robots|sitemap\\.xml|sw\\.js|data/).*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(Googlebot|bingbot|Baiduspider|yandex|facebookexternalhit|Twitterbot|rogerbot|linkedinbot|embedly|showyoubot|outbrain|pinterest|slackbot|vkShare|W3C_Validator|whatsapp|Applebot|AhrefsBot|SemrushBot|DotBot|MJ12bot|PetalBot|Discordbot|TelegramBot).*"
        }
      ],
      "destination": "https://oveuimwssgsadagddtef.supabase.co/functions/v1/prerender?path=/$1"
    },
    { "source": "/(.*)", "destination": "/" }
  ]
}
